{
  "name": "signalwire-docs-specs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "yarn build:api",
    "build:all": "yarn build:api && yarn build:schema",
    "build:api": "yarn build:emit-filter && yarn build:signalwire-rest && yarn build:compatibility-api",
    "build:schema": "yarn build:emit-filter && yarn build:swml-calling && yarn build:swml-messaging",
    "build:emit-filter": "cd ./emitters/typespec-emit-filter && yarn build && cd ../..",
    "build:swml-calling": "cd ./swml/calling && tsp compile . && cd ../",
    "build:swml-messaging": "cd ./swml/messaging && tsp compile . && cd ../",
    "build:signalwire-rest": "cd ./signalwire-rest && tsp compile . && cd ../ && node ./scripts/apply-emit-filter.mjs ../fern/apis/signalwire-rest/openapi.yaml SWMLVar",
    "build:compatibility-api": "cd ./compatibility-api && tsp compile . && cd ../",
    "clean": "echo 'Skipping clean step'",
    "prebuild": "yarn clean",
    "format": "tsp format **/*.tsp",
    "format:check": "tsp format --check **/*.tsp"
  },
  "dependencies": {
    "@signalwire/typespec-emit-filter": "0.0.0",
    "@typespec/compiler": "1.11.0",
    "@typespec/http": "1.11.0",
    "@typespec/json-schema": "1.11.0",
    "@typespec/openapi": "1.11.0",
    "@typespec/openapi3": "1.11.0",
    "@typespec/rest": "0.81.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4",
    "yaml": "2.8.2"
  }
}
