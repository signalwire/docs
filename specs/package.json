{
  "name": "signalwire-docs-specs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "yarn build:api",
    "build:all": "yarn build:api && yarn build:schema",
    "build:api": "yarn build:signalwire-rest && yarn build:compatibility-api",
    "build:schema": "yarn build:swml",
    "build:swml": "cd ./swml && tsp compile . && cd ../",
    "build:signalwire-rest": "cd ./signalwire-rest && tsp compile . && cd ../",
    "build:compatibility-api": "cd ./compatibility-api && tsp compile . && cd ../",
    "clean": "echo 'Skipping clean step'",
    "prebuild": "yarn clean",
    "format": "tsp format **/*.tsp",
    "format:check": "tsp format --check **/*.tsp"
  },
  "dependencies": {
    "@typespec/compiler": "1.10.0",
    "@typespec/http": "1.10.0",
    "@typespec/json-schema": "1.10.0",
    "@typespec/openapi": "1.10.0",
    "@typespec/openapi3": "1.10.0",
    "@typespec/rest": "0.80.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
