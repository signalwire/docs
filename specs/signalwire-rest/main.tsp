import "@typespec/http";
import "@typespec/openapi";
import "./_globally_shared/const.tsp";
import "../_shared/auth.tsp";
import "./types";
import "./calling-api";
import "./voice-api";
import "./message-api";
import "./fax-api";
import "./chat-api";
import "./video-api";
import "./fabric-api";
import "./relay-rest";
import "./project-api";
import "./datasphere-api";
import "./pubsub-api";
import "./logs-api";

using TypeSpec.Http;
using TypeSpec.OpenAPI;

@service(#{ title: "SignalWire REST API" })
@info(#{
  title: "SignalWire REST API",
  version: "1.0.0",
  contact: CONTACT_INFO,
  license: LICENSE_INFO,
  termsOfService: TERMS_OF_SERVICE,
})
@server(
  "https://{space_name}.signalwire.com",
  "SignalWire API",
  {
    @doc("Your SignalWire Space name")
    @example("example")
    space_name: string = "{Your_Space_Name}",
  }
)
@useAuth(SignalWireBasicAuth)
// Calling API
@tagMetadata(CALLS_TAG, CALLS_TAG_METADATA)
// Voice API
@tagMetadata(VOICE_LOGS_TAG, VOICE_LOGS_TAG_METADATA)
