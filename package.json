{
  "name": "signalwire-fern-config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SignalWire Fern documentation configuration",
  "scripts": {
    "start": "npm run fern-check && npx fern docs dev",
    "build": "npm run fern-check && npx fern generate --docs --preview",
    "fern-check": "npx fern check --strict-broken-links",
    "check-links": "node scripts/check-links.js"
  },
  "engines": {
    "node": ">=18"
  }
}
