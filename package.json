{
  "name": "signalwire-fern-config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "SignalWire documentation",
  "workspaces": [
    "specs"
  ],
  "scripts": {
    "start:dev": "fern docs dev",
    "start": "yarn fern-check && fern docs dev",
    "build": "yarn build:specs && fern generate --docs --preview",
    "build:specs": "yarn workspace signalwire-docs-specs build:all",
    "fern-check": "fern check --strict-broken-links",
    "fern-md-check": "fern docs md check",
    "check-links": "node scripts/check-links.js",
    "format:specs": "yarn workspace signalwire-docs-specs format",
    "format:specs:check": "yarn workspace signalwire-docs-specs format:check"
  },
  "devDependencies": {
    "csv-parse": "^6.1.0",
    "fern-api": "^3.48.1",
    "remark-mdx": "^3.1.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "yarn@1.22.22"
}
