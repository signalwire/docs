import "@typespec/http";

using TypeSpec.Http;

@doc("Path parameter for log ID.")
model LogPathID {
  @path
  @format("uuid")
  @doc("Unique ID of the log.")
  @example("c22d24f6-5a47-4597-9a23-c7d01e696b92")
  id: string;
}

@doc("Source of a video log entry.")
enum LogSource {
  @doc("Generated by the Realtime API.")
  realtime_api,
}

@doc("Type of video activity recorded in the log.")
enum LogType {
  @doc("A video room session.")
  video_room_session,

  @doc("A video conference session.")
  video_conference_session,
}

@doc("Status of a video room session.")
enum LogStatus {
  @doc("Session is currently active.")
  `in-progress`,

  @doc("Session has finished.")
  completed,
}

@doc("Charge detail item for logs.")
model ChargeDetail {
  @doc("Description for this charge.")
  @example("Video conference session charge")
  description: string;

  @doc("Charged amount, in dollars.")
  @example(0.005)
  charge: float64;
}

@doc("Log object representing a video activity entry.")
model Log {
  @doc("A unique identifier for the log.")
  @format("uuid")
  @example("c22d24f6-5a47-4597-9a23-c7d01e696b92")
  id: string;

  @doc("Source of this log entry.")
  @example(LogSource.realtime_api)
  source: LogSource;

  @doc("Type of this log entry.")
  @example(LogType.video_conference_session)
  type: LogType;

  @doc("URL for the resource associated with this log entry.")
  @example("https://example.signalwire.com/api/video/room_sessions/a1b2c3d4-5e6f-7890-abcd-ef1234567890")
  url: string;

  @doc("A named unique identifier for the room.")
  @example("my_room")
  room_name: string | null;

  @doc("Status of the log entry.")
  @example(LogStatus.completed)
  status: LogStatus | null;

  @doc("Whether the room session is locked.")
  @example(false)
  locked: boolean;

  @doc("Start time of the activity.")
  @example(utcDateTime.fromISO("2022-01-01T10:00:00Z"))
  started_at: utcDateTime | null;

  @doc("End time of the activity.")
  @example(utcDateTime.fromISO("2022-01-01T11:00:00Z"))
  ended_at: utcDateTime | null;

  @doc("Charge amount for this activity, in dollars.")
  @example(0.01)
  charge: float64;

  @doc("Timestamp when the log was created.")
  @example(utcDateTime.fromISO("2022-01-01T10:00:00Z"))
  created_at: utcDateTime;

  @doc("Details on charges associated with this log.")
  @example(#[#{ description: "Video conference session charge", charge: 0.005 }])
  charge_details: ChargeDetail[];
}

@summary("Deleted Log")
@doc("A discarded/deleted video log entry. Returned when the log has been deleted. Only present when `include_deleted` is `true`.")
model DiscardedLog {
  @format("uuid")
  @doc("A unique identifier for the log.")
  @example("c22d24f6-5a47-4597-9a23-c7d01e696b92")
  id: string;

  @doc("Date and time when the log was discarded.")
  @example(utcDateTime.fromISO("2022-01-01T10:00:00Z"))
  discarded_at: utcDateTime;

  @doc("Date and time when the log was originally created.")
  @example(utcDateTime.fromISO("2022-01-01T10:00:00Z"))
  created_at: utcDateTime;
}

@doc("A video log entry. Discarded logs return only `id`, `discarded_at`, and `created_at`.")
union VideoLog {
  Log,
  DiscardedLog,
}
