{
  "name": "signalwire-docs-website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start-fresh": "yarn run clear && yarn run build:prereqs && yarn run start",
    "build": "yarn run build:root",
    "build:prereqs": "yarn run build:plugins && yarn run clean-and-gen-api-docs",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "gen-api-docs": "docusaurus gen-api-docs all",
    "clean-api-docs": "docusaurus clean-api-docs all",
    "clean-and-gen-api-docs": "yarn run clean-api-docs && yarn run gen-api-docs",
    "llms-txt": "docusaurus llms-txt",
    "llms-txt-clean": "docusaurus llms-txt-clean --clear-cache",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "docsearch-scraper": "docker run -it --env-file=.env -e \"CONFIG=$(cat algolia.json | jq -r tostring)\" --platform linux/amd64 algolia/docsearch-scraper",
    "install-ci": "yarn install --frozen-lockfile --ignore-scripts",
    "build:root": "docusaurus build && yarn run check-links",
    "build:api-docs": "yarn run clean-and-gen-api-docs",
    "build:remark-plugin-image-to-figure": "yarn --cwd src/plugins/remark-plugin-image-to-figure run build",
    "build:plugins": "yarn run build:remark-plugin-image-to-figure",
    "check-links": "node scripts/check-links.js"
  },
  "dependencies": {
    "@docusaurus/core": "^3.9.1",
    "@docusaurus/faster": "^3.9.1",
    "@docusaurus/module-type-aliases": "^3.9.1",
    "@docusaurus/preset-classic": "^3.9.1",
    "@docusaurus/remark-plugin-npm2yarn": "^3.9.1",
    "@docusaurus/theme-mermaid": "^3.9.1",
    "@docusaurus/tsconfig": "^3.9.1",
    "@mermaid-js/layout-elk": "^0.1.4",
    "@docusaurus/types": "^3.9.1",
    "@mdx-js/react": "^3.0.1",
    "@signalwire/docusaurus-plugin-llms-txt": "2.0.0-alpha.7",
    "@signalwire/docusaurus-theme-llms-txt": "1.0.0-alpha.9",
    "clsx": "^2.1.1",
    "docusaurus-plugin-openapi-docs": "0.0.0-1054",
    "docusaurus-plugin-sass": "0.2.6",
    "docusaurus-theme-openapi-docs": "0.0.0-1054",
    "docusaurus-theme-search-typesense": "^0.25.0",
    "dompurify": "^3.2.4",
    "dotenv": "^16.4.5",
    "plugin-image-zoom": "flexanalytics/plugin-image-zoom",
    "prism-react-renderer": "^2.3.1",
    "pushfeedback-react": "^0.1.73",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-icons": "^5.4.0",
    "react-markdown": "^10.1.0",
    "react-slick": "^0.30.2",
    "sass": "1.82.0",
    "slick-carousel": "^1.8.1",
    "yaml": "^2.5.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react-dom": "19.0.0",
    "@types/react-slick": "^0.23.13",
    "linkinator": "^6.1.2",
    "prettier": "^3.3.3",
    "sharp": "^0.33.4",
    "shx": "^0.3.4",
    "typescript": "^5.5.4"
  }
}
