{
  "name": "video-conference-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file=.env server/index.ts",
    "build": "tsc && vite build"
  },
  "dependencies": {
    "@signalwire/js": "4.0.0-beta.12",
    "cookie-parser": "^1.4.6",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vite": "^7.2.2"
  }
}
